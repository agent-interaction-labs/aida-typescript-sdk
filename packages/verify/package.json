{
  "name": "@aida/verify",
  "version": "0.1.0",
  "description": "AIDA Verify SDK — server-side verification of AIDA agent identities, RFC 9421 signatures, and identity documents",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md", "SECURITY.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && node scripts/build-cjs.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["aida", "verify", "identity", "ed25519", "rfc9421", "http-signatures", "middleware", "express"],
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-interaction-labs/aida-typescript-sdk"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.7.0",
    "base58-universal": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
